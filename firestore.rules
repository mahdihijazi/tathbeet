rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentEmail() {
      return signedIn() ? request.auth.token.email : null;
    }

    function profilePath(profileId) {
      return /databases/$(database)/documents/profiles/$(profileId);
    }

    function memberPath(profileId, memberId) {
      return /databases/$(database)/documents/profiles/$(profileId)/members/$(memberId);
    }

    function profileExists(profileId) {
      return exists(profilePath(profileId));
    }

    function profileExistsAfter(profileId) {
      return existsAfter(profilePath(profileId));
    }

    function profileOwnerId(profileId) {
      return profileExists(profileId) ? get(profilePath(profileId)).data.ownerUserId : null;
    }

    function profileOwnerIdAfter(profileId) {
      return profileExistsAfter(profileId) ? getAfter(profilePath(profileId)).data.ownerUserId : null;
    }

    function isProfileOwner(profileId) {
      return signedIn() && profileOwnerId(profileId) == request.auth.uid;
    }

    function isProfileOwnerAfter(profileId) {
      return signedIn() && profileOwnerIdAfter(profileId) == request.auth.uid;
    }

    function memberExists(profileId, memberId) {
      return exists(memberPath(profileId, memberId));
    }

    function memberData(profileId, memberId) {
      return memberExists(profileId, memberId) ? get(memberPath(profileId, memberId)).data : null;
    }

    function isCurrentUserMember(profileId) {
      return signedIn()
        && currentEmail() != null
        && memberExists(profileId, currentEmail())
        && memberData(profileId, currentEmail()).email == currentEmail();
    }

    function isCurrentUserMemberWithRole(profileId, role) {
      return isCurrentUserMember(profileId)
        && memberData(profileId, currentEmail()).role == role;
    }

    function isSelfClaimingMemberUpdate(profileId, memberId) {
      return signedIn()
        && currentEmail() != null
        && memberId == currentEmail()
        && memberExists(profileId, memberId)
        && memberData(profileId, memberId).email == currentEmail()
        && request.resource.data.email == memberData(profileId, memberId).email
        && request.resource.data.role == memberData(profileId, memberId).role
        && request.resource.data.userId == request.auth.uid;
    }

    function canLeaveMember(profileId, memberId) {
      return signedIn()
        && currentEmail() != null
        && memberId == currentEmail()
        && memberExists(profileId, memberId)
        && memberData(profileId, memberId).userId == request.auth.uid
        && memberData(profileId, memberId).role == "Editor";
    }

    function canReadProfile(profileId) {
      return isProfileOwner(profileId) || isCurrentUserMember(profileId);
    }

    function canWriteProfileChildren(profileId) {
      return isProfileOwner(profileId)
        || isProfileOwnerAfter(profileId)
        || isCurrentUserMemberWithRole(profileId, "Owner")
        || isCurrentUserMemberWithRole(profileId, "Editor");
    }

    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;

      match /accessibleProfiles/{profileId} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow create, update, delete: if signedIn()
          && (request.auth.uid == uid || isProfileOwner(profileId));
      }
    }

    match /profiles/{profileId} {
      allow read: if canReadProfile(profileId);
      allow create: if signedIn() && request.resource.data.ownerUserId == request.auth.uid;
      allow update, delete: if isProfileOwner(profileId);

      match /members/{memberId} {
        allow read: if isProfileOwner(profileId)
          || (signedIn() && currentEmail() != null && memberId == currentEmail())
          || (signedIn()
            && memberExists(profileId, memberId)
            && memberData(profileId, memberId).userId == request.auth.uid);

        allow create: if isProfileOwner(profileId) || isProfileOwnerAfter(profileId);

        allow update: if isProfileOwner(profileId)
          || isSelfClaimingMemberUpdate(profileId, memberId);

        allow delete: if isProfileOwner(profileId)
          || canLeaveMember(profileId, memberId);
      }

      match /plan/{planId} {
        allow read, write: if planId == "meta" && canWriteProfileChildren(profileId);
      }

      match /reviewDays/{dateId} {
        allow read, write: if canWriteProfileChildren(profileId);
      }

      match /tasks/{taskId} {
        allow read, write: if canWriteProfileChildren(profileId);
      }
    }
  }
}
